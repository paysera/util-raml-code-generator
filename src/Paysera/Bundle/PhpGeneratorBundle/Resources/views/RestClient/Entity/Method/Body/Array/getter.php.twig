    /**
     * @return {% include get_method_return_type_template(property) with { 'property': property } only %}
     */
    public function {{ php_generate_getter_name(property) }}()
    {
    {% if property.itemsType in property.simpleTypes %}
    return $this->get('{{ property.name }}');
    {% else %}
    {% set itemConfiguration = get_item_type_configuration(property) %}
    $items = $this->getByReference('{{ property.name }}');
        if ($items === null) {
            return [];
        }

        $list = [];
        foreach($items as &$item) {
            {% if itemConfiguration.arrayItemPopulatorCode is not null %}
            $list[] = {{ itemConfiguration.arrayItemPopulatorCode|raw }};
            {% else %}
            $list[] = (new {{ property.itemsType|extract_type_name }}())->setDataByReference($item);
            {% endif %}
        }

        return $list;
    {% endif %}
}
